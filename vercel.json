{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    {
      "source": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "source": "/(.*)",
      "dest": "/$1"
    }
  ],
  "outputDirectory": "frontend/dist"
}
